# ============================================
# 投研协作平台 - 环境变量配置
# ============================================

# ---------- 通用 ----------
APP_NAME=investment-research-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string

# ---------- 数据库 ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_platform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/research_platform
DB_ECHO=false

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
REDIS_EVENT_BUS_DB=1
REDIS_CACHE_DB=2

# ---------- MinIO (S3) ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=research-documents
MINIO_USE_SSL=false

# ---------- JWT ----------
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---------- OpenClaw / AI ----------
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_MODEL=claude-opus-4-6
OPENCLAW_BASE_URL=http://localhost:8080

# LLM 备用配置
LLM_PROVIDER=openclaw
LLM_MODEL=claude-opus-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding 模型
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ---------- Celery ----------
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4

# ---------- 推送 ----------
# 邮件
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password

# 企业微信 Webhook (可选)
WECOM_WEBHOOK_URL=

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000"]
