# ============================================
# 投研协作平台 - 环境变量配置示例
# ============================================
# 复制此文件为 .env.prod 或 .env 并填入真实值

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://research_user:secure_password@postgres:5432/research_platform
DATABASE_SYNC_URL=postgresql://research_user:secure_password@postgres:5432/research_platform

# ============================================
# Redis配置
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# 认证与安全
# ============================================
# 使用 openssl rand -hex 32 生成
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ============================================
# CORS跨域配置
# ============================================
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ============================================
# AI / LLM API配置 (OpenClaw必需)
# ============================================
# OpenAI API
LLM_API_KEY=sk-your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# 可选: Moonshot (Kimi)
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here

# 可选: DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ============================================
# OpenClaw配置 (NEW! 核心功能)
# ============================================
OPENCLAW_BASE_URL=http://openclaw:18789
OPENCLAW_API_KEY=your-openclaw-api-key-change-me
OPENCLAW_ENABLED=true
OPENCLAW_TIMEOUT=300

# 后端API密钥(供OpenClaw技能调用后端)
BACKEND_API_KEY=your-backend-api-key-for-openclaw

# ============================================
# 文件存储 (默认MinIO)
# ============================================
# MinIO (本地S3兼容存储)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=research-docs
MINIO_SECURE=false

# 可选: 阿里云OSS
# OSS_ACCESS_KEY=your-oss-access-key
# OSS_SECRET_KEY=your-oss-secret-key
# OSS_BUCKET=research-docs
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ============================================
# Celery任务队列 (可选)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

# ============================================
# 应用配置
# ============================================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# 安全提示
# ============================================
# 1. 所有密码和密钥务必使用强随机值
# 2. 生产环境不要使用默认密码
# 3. 不要将 .env 文件提交到Git
# 4. LLM_API_KEY 是OpenClaw功能的必需配置
